{{- $codex := dict -}}
{{- if hasKey . "codex" -}}
{{- $codex = index . "codex" -}}
{{- end -}}
{{- $extraAllowPrefixRules := list -}}
{{- if hasKey $codex "extra_allow_prefix_rules" -}}
{{- $extraAllowPrefixRules = index $codex "extra_allow_prefix_rules" -}}
{{- end -}}
{{- $extraPromptPrefixRules := list -}}
{{- if hasKey $codex "extra_prompt_prefix_rules" -}}
{{- $extraPromptPrefixRules = index $codex "extra_prompt_prefix_rules" -}}
{{- end -}}
{{- $extraForbiddenPrefixRules := list -}}
{{- if hasKey $codex "extra_forbidden_prefix_rules" -}}
{{- $extraForbiddenPrefixRules = index $codex "extra_forbidden_prefix_rules" -}}
{{- end -}}
