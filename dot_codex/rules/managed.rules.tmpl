# 追加コマンド
{{- range $extraAllowPrefixRules }}
prefix_rule(pattern=[{{- range $idx, $token := splitList " " . }}{{ if gt $idx 0 }}, {{ end }}{{ $token | toJson }}{{- end }}], decision="allow")
{{- end }}
{{- range $extraPromptPrefixRules }}
prefix_rule(pattern=[{{- range $idx, $token := splitList " " . }}{{ if gt $idx 0 }}, {{ end }}{{ $token | toJson }}{{- end }}], decision="prompt")
{{- end }}
{{- range $extraForbiddenPrefixRules }}
prefix_rule(pattern=[{{- range $idx, $token := splitList " " . }}{{ if gt $idx 0 }}, {{ end }}{{ $token | toJson }}{{- end }}], decision="forbidden")
{{- end }}
