# Keep .zshenv minimal and safe for all shells.
typeset -U path PATH

path=(
  "$HOME/.local/bin"
  "$HOME/local/bin"
  "$HOME/bin"
  $path
)

{{- if eq .chezmoi.os "darwin" }}
path=(
  /opt/homebrew/bin
  /usr/local/bin
  $path
)
{{- else }}
path=(
  /usr/local/bin
  $path
)
{{- end }}

export PYENV_ROOT="$HOME/.pyenv"
export NVM_DIR="$HOME/.nvm"
