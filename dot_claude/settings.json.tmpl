      {{ . | toJson }}{{- end }}
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message '確認して！' -subtitle $(basename \"$PWD\") -sound default"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -message '作業終わったよ〜' -subtitle $(basename \"$PWD\") -sound default"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "plugin-dev@anthropics/claude-code": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowUnixSockets": [
        "~/.orbstack/run/docker.sock",
        "~/.docker/run/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "./work"
      ]
    },
    "excludedCommands": [
      "docker",
      "git",
      "gh",
      "mise"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "skipWorkflowUsageWarning": true,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true
}
