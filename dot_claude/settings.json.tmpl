    "deny": [
      "Bash(aws iam create-*:*)",
      "Bash(aws iam delete-*:*)",
      "Bash(aws iam attach-*:*)",
      "Bash(aws iam detach-*:*)",
      "Bash(aws iam put-*:*)",
      "Bash(aws iam update-*:*)",
      "Bash(aws iam set-*:*)",
      "Bash(aws iam remove-*:*)",
      "Bash(aws kms encrypt:*)",
