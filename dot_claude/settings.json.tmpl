      "Bash(aws ecs register-task-definition:*)",
      "Bash(aws cloudformation create-*:*)",
      "Bash(aws cloudformation update-*:*)",
      "Bash(aws cloudformation deploy:*)",
      "Bash(aws cloudformation execute-change-set:*)",
      "Bash(aws ssm send-command:*)",
