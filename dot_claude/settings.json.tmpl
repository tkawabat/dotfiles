      "Skill(agent-browser *)",
      "Skill(plugin-dev:*)",
      "Skill(skill-creator *)",
      "Skill(tech-docs:*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:github.com)",
      "mcp__atlassian",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__linear__get*",
      "mcp__linear__list*",
      "mcp__notion__notion-search",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-get-comments",
      "mcp__plugin_context7_context7",
      "Bash(curl * localhost*)",
      "Bash(curl * 127.0.0.1*)",
      "Bash(curl *//localhost*)",
      "Bash(curl *//127.0.0.1*)"{{- range $extraAllow }},
      {{ . | toJson }}{{- end }}
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(git branch -d:*)",
