[user]
	name = tkawabat
	email = tosiki.kawabata@gmail.com
[alias]
	st = status
	co = commit
	ch = checkout
	br = branch
	pr = pull --rebase
    swc = "!sh -c 'git fetch origin \"$1\" && git switch -c \"$1\" \"origin/$1\"' -"
    cleanup = "!sh -c 'git fetch --prune; git branch --merged origin/HEAD | grep -v main | xargs -r git branch -D'"
[core]
	editor = vim
