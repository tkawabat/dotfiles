# vi style keybindings
bindkey -v

# Completion setup
{{- if eq .chezmoi.os "darwin" }}
if [ -d /usr/local/share/zsh-completions ]; then
  fpath=(/usr/local/share/zsh-completions $fpath)
fi
{{- end }}
autoload -Uz compinit
compinit -u
[[ -d "$HOME/.zsh/cache" ]] || mkdir -p "$HOME/.zsh/cache"
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$HOME/.zsh/cache"
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}' 'r:|[._-]=* r:|=*'

PROMPT='%~$ '

setopt auto_pushd
setopt pushd_ignore_dups
setopt extended_glob
setopt interactive_comments

export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=1000
export SAVEHIST=100000
setopt hist_ignore_all_dups
setopt hist_ignore_space
setopt append_history
setopt inc_append_history
setopt share_history
setopt hist_expire_dups_first
setopt hist_reduce_blanks
setopt hist_verify
zstyle ':completion:*:default' menu select=1
WORDCHARS='*?_-.[]~=&;!#$%^(){}<>'

alias ll='ls -al'
alias rm='rm -i'
alias svim='sudo vim'
alias jgrep='grep -R --exclude-dir=".git" --exclude-dir="log" --exclude="*.min.*" --exclude="package*json" --exclude-dir="node_modules"'

typeset -U path PATH
path=(
  "$HOME/.antigravity/antigravity/bin"
  "$HOME/pkg/flutter/bin"
  "$HOME/.pub-cache/bin"
  "$HOME/.local/bin"
  "$HOME/local/bin"
  $path
)
{{- if eq .chezmoi.os "darwin" }}
path=(
  /opt/homebrew/bin
  $path
)
{{- end }}

# tmux builds sometimes depend on local libs.
export LD_LIBRARY_PATH="$HOME/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

# Host-local settings and secrets are managed outside this repository.
if [ -r "$HOME/.local_zsh_rc" ]; then
  source "$HOME/.local_zsh_rc"
fi

# pyenv
if [ -d "$PYENV_ROOT/bin" ]; then
  path=("$PYENV_ROOT/bin" "$PYENV_ROOT/shims" $path)
fi
if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init - zsh)"
  if command -v pyenv-virtualenv-init >/dev/null 2>&1; then
    eval "$(pyenv virtualenv-init -)"
  fi
fi

# gcloud helper scripts for manual SDK installs.
{{- if eq .chezmoi.os "darwin" }}
if [ -f "$HOME/pkg/google-cloud-sdk/path.zsh.inc" ]; then
  . "$HOME/pkg/google-cloud-sdk/path.zsh.inc"
fi
if [ -f "$HOME/pkg/google-cloud-sdk/completion.zsh.inc" ]; then
  . "$HOME/pkg/google-cloud-sdk/completion.zsh.inc"
fi
{{- else }}
if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then
  . "$HOME/google-cloud-sdk/path.zsh.inc"
fi
if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then
  . "$HOME/google-cloud-sdk/completion.zsh.inc"
fi
{{- end }}

# nvm
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
  if [ -s "$NVM_DIR/bash_completion" ]; then
    . "$NVM_DIR/bash_completion"
  fi
  if command -v nvm >/dev/null 2>&1 && nvm alias default >/dev/null 2>&1; then
    nvm use --silent default >/dev/null 2>&1
  fi
fi
